# Caracal runtime environment template. The CLI seeds this with random secrets on first install.

POSTGRES_USER=caracal
POSTGRES_PASSWORD=
POSTGRES_DB=caracal

REDIS_PASSWORD=

CARACAL_ADMIN_TOKEN=

# Optional: S3-compatible endpoint for audit Parquet export (leave blank to disable)
AUDIT_EXPORT_S3_ENDPOINT=
AUDIT_EXPORT_S3_BUCKET=
