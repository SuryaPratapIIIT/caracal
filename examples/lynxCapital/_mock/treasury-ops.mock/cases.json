{
  "service": "treasury-ops",
  "actions": {
    "get_cash_position": {
      "match_key": "region",
      "cases": {
        "US": {"region": "US", "cash_usd": 12450000.00, "operating": 8200000.00, "reserves": 4250000.00, "as_of": "2026-05-09"},
        "IN": {"region": "IN", "cash_usd": 3120000.00, "operating": 2100000.00, "reserves": 1020000.00, "as_of": "2026-05-09"},
        "DE": {"region": "DE", "cash_usd": 6980000.00, "operating": 4400000.00, "reserves": 2580000.00, "as_of": "2026-05-09"},
        "SG": {"region": "SG", "cash_usd": 2410000.00, "operating": 1600000.00, "reserves": 810000.00, "as_of": "2026-05-09"},
        "BR": {"region": "BR", "cash_usd": 1830000.00, "operating": 1200000.00, "reserves": 630000.00, "as_of": "2026-05-09"},
        "default": {"region": "GLOBAL", "cash_usd": 26790000.00, "operating": 17500000.00, "reserves": 9290000.00, "as_of": "2026-05-09"}
      }
    },
    "forecast_liquidity": {
      "match_key": "horizon_days",
      "cases": {
        "7":  {"horizon_days": 7,  "outflow_usd": 8500000.00, "inflow_usd": 7200000.00, "net": -1300000.00, "shortfall_risk": "low"},
        "30": {"horizon_days": 30, "outflow_usd": 32100000.00, "inflow_usd": 29800000.00, "net": -2300000.00, "shortfall_risk": "medium"},
        "90": {"horizon_days": 90, "outflow_usd": 94500000.00, "inflow_usd": 91200000.00, "net": -3300000.00, "shortfall_risk": "medium"},
        "default": {"horizon_days": 30, "outflow_usd": 32100000.00, "inflow_usd": 29800000.00, "net": -2300000.00, "shortfall_risk": "medium"}
      }
    },
    "place_fx_hedge": {
      "match_key": ["from_currency", "to_currency"],
      "cases": {
        "USD|EUR": {"hedge_id": "FXH-USDEUR-001", "from_currency": "USD", "to_currency": "EUR", "notional": 1000000.00, "forward_rate": 0.9210, "tenor_days": 90, "status": "filled"},
        "USD|INR": {"hedge_id": "FXH-USDINR-001", "from_currency": "USD", "to_currency": "INR", "notional": 1000000.00, "forward_rate": 83.45, "tenor_days": 90, "status": "filled"},
        "USD|BRL": {"hedge_id": "FXH-USDBRL-001", "from_currency": "USD", "to_currency": "BRL", "notional": 1000000.00, "forward_rate": 5.12, "tenor_days": 90, "status": "filled"},
        "USD|SGD": {"hedge_id": "FXH-USDSGD-001", "from_currency": "USD", "to_currency": "SGD", "notional": 1000000.00, "forward_rate": 1.34, "tenor_days": 90, "status": "filled"},
        "default": {"hedge_id": "FXH-DFLT-001", "from_currency": null, "to_currency": null, "notional": 0.00, "forward_rate": 0.0, "tenor_days": 90, "status": "rejected", "error": "UNSUPPORTED_PAIR"}
      }
    },
    "transfer_funds": {
      "match_key": ["from_region", "to_region"],
      "cases": {
        "US|DE": {"transfer_id": "TR-USDE-001", "from_region": "US", "to_region": "DE", "amount_usd": 500000.00, "status": "settled", "value_date": "2026-05-10"},
        "US|IN": {"transfer_id": "TR-USIN-001", "from_region": "US", "to_region": "IN", "amount_usd": 500000.00, "status": "settled", "value_date": "2026-05-10"},
        "default": {"transfer_id": "TR-DFLT-001", "from_region": null, "to_region": null, "amount_usd": 0.00, "status": "submitted", "value_date": "2026-05-10"}
      }
    }
  }
}
