{
  "service": "customer-billing",
  "actions": {
    "issue_customer_invoice": {
      "match_key": "customer_id",
      "cases": {
        "cust-globex":   {"invoice_id": "INV-CUS-GLB-001", "customer_id": "cust-globex",   "amount": 145000.00, "currency": "USD", "due_date": "2026-06-08", "status": "issued"},
        "cust-helios":   {"invoice_id": "INV-CUS-HLS-001", "customer_id": "cust-helios",   "amount": 84200.00,  "currency": "EUR", "due_date": "2026-06-08", "status": "issued"},
        "cust-ariadne":  {"invoice_id": "INV-CUS-ARN-001", "customer_id": "cust-ariadne",  "amount": 52000.00,  "currency": "USD", "due_date": "2026-06-08", "status": "issued"},
        "default":       {"invoice_id": "INV-CUS-DFLT-001","customer_id": null,            "amount": 0.00,      "currency": "USD", "due_date": "2026-06-08", "status": "issued"}
      }
    },
    "send_dunning_notice": {
      "match_key": "customer_id",
      "cases": {
        "cust-overdue-1": {"customer_id": "cust-overdue-1", "stage": 1, "balance": 18400.00, "currency": "USD", "days_overdue": 12, "status": "sent"},
        "cust-overdue-2": {"customer_id": "cust-overdue-2", "stage": 2, "balance": 92000.00, "currency": "USD", "days_overdue": 38, "status": "sent"},
        "cust-overdue-3": {"customer_id": "cust-overdue-3", "stage": 3, "balance": 240000.00,"currency": "USD", "days_overdue": 75, "status": "escalated_to_collections"},
        "default":        {"customer_id": null,             "stage": 1, "balance": 0.00,     "currency": "USD", "days_overdue": 0,  "status": "sent"}
      }
    },
    "apply_customer_payment": {
      "match_key": "invoice_id",
      "cases": {
        "INV-CUS-GLB-001":  {"invoice_id": "INV-CUS-GLB-001", "applied": 145000.00, "remaining": 0.00,   "currency": "USD", "status": "paid"},
        "INV-CUS-HLS-001":  {"invoice_id": "INV-CUS-HLS-001", "applied": 50000.00,  "remaining": 34200.00,"currency": "EUR", "status": "partial"},
        "INV-CUS-UNMATCH":  {"invoice_id": "INV-CUS-UNMATCH", "applied": 0.00,      "remaining": 0.00,   "currency": "USD", "status": "unmatched", "error": "INVOICE_NOT_FOUND"},
        "default":          {"invoice_id": null,              "applied": 0.00,      "remaining": 0.00,   "currency": "USD", "status": "paid"}
      }
    },
    "get_ar_aging": {
      "match_key": "region",
      "cases": {
        "US": {"region": "US", "current": 4250000.00, "d30": 820000.00, "d60": 240000.00, "d90_plus": 95000.00},
        "DE": {"region": "DE", "current": 2120000.00, "d30": 380000.00, "d60": 105000.00, "d90_plus": 32000.00},
        "IN": {"region": "IN", "current": 980000.00,  "d30": 220000.00, "d60": 78000.00,  "d90_plus": 41000.00},
        "default": {"region": "GLOBAL", "current": 7350000.00, "d30": 1420000.00, "d60": 423000.00, "d90_plus": 168000.00}
      }
    }
  }
}
