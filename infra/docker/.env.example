#
# Local-dev environment template. Copy to `.env` and fill in values.

POSTGRES_USER=caracal
POSTGRES_PASSWORD=changeMe
POSTGRES_DB=caracal

REDIS_PASSWORD=changeMe

CARACAL_ADMIN_TOKEN=changeMe

# 32-byte hex-encoded secrets. Generate with: openssl rand -hex 32
ZONE_KEK=
AUDIT_HMAC_KEY=
STREAMS_HMAC_KEY=

# Populated by `caracal init` after the local zone is provisioned.
RESOURCE_CLIENT_BINDINGS=

# Local-dev escape hatches: required for the local stack to start without TLS
# certificates and to expose the one-shot bootstrap route used by `caracal init`.
# Never enable these in a non-local environment.
INSECURE_STS=true
INSECURE_HTTP=true
CARACAL_LOCAL_BOOTSTRAP_ENABLED=true

# Optional: S3-compatible endpoint for audit Parquet export (leave blank to disable)
AUDIT_EXPORT_S3_ENDPOINT=
AUDIT_EXPORT_S3_BUCKET=
